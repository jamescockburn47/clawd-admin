# Required
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model
CLAUDE_MODEL=claude-sonnet-4-6

# WhatsApp
WHATSAPP_GROUP_JID=
PAIRING_PHONE_NUMBER=
OWNER_JID=

# Trigger config
TRIGGER_PREFIX=/clawd
RANDOM_REPLY_CHANCE=0.05
KEYWORD_BOOST_CHANCE=0.25
RANDOM_COOLDOWN_SECONDS=300

# Cost control
CONTEXT_MESSAGE_COUNT=10
MAX_RESPONSE_TOKENS=1000
DAILY_CALL_LIMIT=100
AUTH_STATE_PATH=./auth_state

# Google OAuth (calendar + gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Travel APIs
DARWIN_TOKEN=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Web Search (Brave Search API — free tier: 2000 queries/month)
BRAVE_API_KEY=

# Dashboard
HTTP_PORT=3000
DASHBOARD_TOKEN=

# EVO X2 — llama-server (OpenAI-compatible) + memory service (prefer direct Ethernet IPs)
EVO_LLM_URL=http://10.0.0.2:8080
EVO_CLASSIFIER_URL=http://10.0.0.2:8081
EVO_TOOL_ENABLED=true
EVO_MEMORY_URL=http://10.0.0.2:5100
EVO_MEMORY_ENABLED=true
# Optional labels for system_status tool (defaults are sensible)
# EVO_MAIN_MODEL_LABEL=
# EVO_CLASSIFIER_LABEL=

# Weather
WEATHER_ENABLED=true
WEATHER_LOCATIONS=London,York

# Morning briefing
BRIEFING_ENABLED=true
BRIEFING_TIME=07:00

# Logging
LOG_LEVEL=info
