[Unit]
Description=Pin AMD GPU clock to highest performance state
After=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'echo profile_peak > /sys/class/drm/card1/device/power_dpm_force_performance_level'
ExecStop=/bin/bash -c 'echo auto > /sys/class/drm/card1/device/power_dpm_force_performance_level'

[Install]
WantedBy=multi-user.target
